state "Story Execution Context" as story_execution_context {
  state "Story 1 [completed]\nEstablish Runtime Boundary\ndepends: -\ntrail: -\nCreate the runtime module.\nCovers: Contract Runtime Boundary" as story_execution_context_1 #90be6d
  state "Story 2 [active]\nAdd Approval Policy\ndepends: Story 1\ntrail: story-enrichment -> implementation-planning\nAdd approval-gated behavior.\nCovers: Approval And Decision Governance" as story_execution_context_2 #8ecae6
  story_execution_context_1 --> story_execution_context_2
  state "Story 3 [future]\nAdd Audit Trail\ndepends: Story 1\ntrail: -\nPersist audit events.\nCovers: Audit Trail And Timeline Reconstruction" as story_execution_context_3 #d9d9d9
  story_execution_context_2 --> story_execution_context_3
  state "Story 4 [deferred]\nDocument Operations\ndepends: Story 2, Story 3\ntrail: -\nWrite operator guidance.\nCovers: Developer Guidance" as story_execution_context_4 #f9c74f
  story_execution_context_3 --> story_execution_context_4
