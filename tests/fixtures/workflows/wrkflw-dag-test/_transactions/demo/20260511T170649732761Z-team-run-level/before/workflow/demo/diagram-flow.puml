@startuml
title Workflow Flow: demo
skinparam shadowing false
skinparam defaultFontName Monospaced
hide empty description
[*] --> discuss
state "discuss\ngoal framing\nactive: Story 2" as discuss #90be6d
state "capability-review\ncapability gate\nauto: off" as capability_review #90be6d
state "epic-shaping\nepic review\nauto: off" as epic_shaping #90be6d
state "story-slicing\n4 stories\nauto: off" as story_slicing #90be6d
state "story-enrichment\nenriching Story 2\nauto: off" as story_enrichment #90be6d
state "spec-authoring\nOpenSpec\nauto: off" as spec_authoring #90be6d
state "implementation-planning\nplan slice\nactive: Story 2" as implementation_planning #8ecae6
state "implementation\nbuild/test\nactive: Story 2" as implementation #d9d9d9
state "review\nreview gate\nauto: off" as review #d9d9d9
state "release-planning\nrelease prep\nauto: off" as release_planning #d9d9d9
state "done\ncomplete" as done #d9d9d9
discuss --> capability_review
capability_review --> epic_shaping
epic_shaping --> story_slicing
story_slicing --> story_enrichment
story_enrichment --> spec_authoring
spec_authoring --> implementation_planning
implementation_planning --> implementation
implementation --> review
review --> release_planning
release_planning --> done
done --> [*]
